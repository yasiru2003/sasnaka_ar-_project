generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Participant {
  id                 String   @id @default(uuid())
  registrationNumber String   @unique
  name               String
  email              String   @unique
  district           String
  category           String
  entry_video_url    String?
  created_at         DateTime @default(now())
}
